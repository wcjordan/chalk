{
  "hooks": {
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": ".claude/hooks/setup-new-worktree.sh" }]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": ".claude/hooks/stop-verify.sh", "timeout": 300 }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/block-force-push.sh" }]
      }
    ]
  }
}
